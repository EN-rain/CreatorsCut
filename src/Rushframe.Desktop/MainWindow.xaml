<Window x:Class="Rushframe.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:Rushframe.Desktop.Commands"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Rushframe"
        Width="1500"
        Height="900"
        MinWidth="1180"
        MinHeight="720"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.CommandBindings>
        <CommandBinding Command="c:EditorCommands.TogglePanel" Executed="TogglePanel_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <ContextMenu x:Key="TimelineClipContextMenu">
            <MenuItem Header="Split at Playhead" Command="c:EditorCommands.SplitClip" InputGestureText="Ctrl+B" />
            <Separator />
            <MenuItem Header="Cut" Command="c:EditorCommands.Cut" InputGestureText="Ctrl+X" />
            <MenuItem Header="Copy" Command="c:EditorCommands.Copy" InputGestureText="Ctrl+C" />
            <MenuItem Header="Paste" Command="c:EditorCommands.Paste" InputGestureText="Ctrl+V" />
            <MenuItem Header="Duplicate" Command="c:EditorCommands.Duplicate" InputGestureText="Ctrl+D" />
            <Separator />
            <MenuItem Header="Ripple Delete" Command="c:EditorCommands.RippleDelete" />
            <MenuItem Header="Delete" Command="c:EditorCommands.DeleteClip" InputGestureText="Delete" />
        </ContextMenu>

        <ContextMenu x:Key="TrackHeaderContextMenu">
            <MenuItem Header="Rename Track" x:Name="RenameTrackMenuItem" />
            <MenuItem Header="Duplicate Track" x:Name="DuplicateTrackMenuItem" />
            <Separator />
            <MenuItem Header="Mute Track" x:Name="MuteTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Solo Track" x:Name="SoloTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Lock Track" x:Name="LockTrackMenuItem" IsCheckable="True" />
            <Separator />
            <MenuItem Header="Delete Track" x:Name="DeleteTrackMenuItem" />
        </ContextMenu>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="0" />
            <RowDefinition Height="*" />
            <RowDefinition Height="25" />
        </Grid.RowDefinitions>

        <!-- Top command bar -->
        <Border Grid.Row="0"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Menu>
                        <MenuItem Header="File">
                            <MenuItem Header="Open Project" Command="c:EditorCommands.OpenProject" InputGestureText="Ctrl+O" />
                            <MenuItem Header="Save Project" Command="c:EditorCommands.SaveProject" InputGestureText="Ctrl+S" />
                            <Separator />
                            <MenuItem Header="Import Media" Command="c:EditorCommands.ImportMedia" InputGestureText="Ctrl+I" />
                            <MenuItem Header="Relink Selected Media" Command="c:EditorCommands.RelinkMedia" />
                            <MenuItem Header="Generate Media Cache" Command="c:EditorCommands.GenerateMediaCache" />
                            <Separator />
                            <MenuItem Header="Export" Command="c:EditorCommands.Render" InputGestureText="Ctrl+R" />
                        </MenuItem>
                        <MenuItem Header="Edit">
                            <MenuItem Header="Undo" Command="c:EditorCommands.Undo" InputGestureText="Ctrl+Z" />
                            <MenuItem Header="Redo" Command="c:EditorCommands.Redo" InputGestureText="Ctrl+Y" />
                            <Separator />
                            <MenuItem Header="Cut" Command="c:EditorCommands.Cut" InputGestureText="Ctrl+X" />
                            <MenuItem Header="Copy" Command="c:EditorCommands.Copy" InputGestureText="Ctrl+C" />
                            <MenuItem Header="Paste" Command="c:EditorCommands.Paste" InputGestureText="Ctrl+V" />
                            <MenuItem Header="Duplicate" Command="c:EditorCommands.Duplicate" InputGestureText="Ctrl+D" />
                            <Separator />
                            <MenuItem Header="Split at Playhead" Command="c:EditorCommands.SplitClip" InputGestureText="Ctrl+B" />
                            <MenuItem Header="Delete" Command="c:EditorCommands.DeleteClip" InputGestureText="Delete" />
                        </MenuItem>
                        <MenuItem Header="View">
                            <MenuItem Header="Panels" x:Name="PanelsMenu" />
                        </MenuItem>
                        <MenuItem Header="Timeline">
                            <MenuItem Header="Add Text" Command="c:EditorCommands.AddText" InputGestureText="Ctrl+T" />
                            <MenuItem Header="Add Marker" Command="c:EditorCommands.AddMarker" />
                            <MenuItem Header="Extract Audio" Command="c:EditorCommands.ExtractAudio" />
                        </MenuItem>
                    </Menu>
                    <Border Width="1" Height="24" Background="{StaticResource BorderBrush}" Margin="10,0" />
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.OpenProject" ToolTip="Open project (Ctrl+O)">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M2,5 L7,5 L9,7 L16,7 L15,15 L2,15 Z M2,5 L2,3 L8,3 L10,5" /><TextBlock Text="Open" /></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.SaveProject" ToolTip="Save project (Ctrl+S)">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M3,2 L14,2 L16,4 L16,16 L2,16 L2,2 Z M5,2 L5,7 L13,7 L13,2 M5,11 L13,11 L13,16 L5,16 Z" /><TextBlock Text="Save" /></StackPanel>
                    </Button>
                    <Border Width="1" Height="24" Background="{StaticResource BorderBrush}" Margin="7,0" />
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.ImportMedia" ToolTip="Import media (Ctrl+I)">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M9,2 L9,11 M5.5,5.5 L9,2 L12.5,5.5 M3,11 L3,15 L15,15 L15,11" /><TextBlock Text="Import" /></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.AddText" ToolTip="Add text clip (Ctrl+T)">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M3,3 L15,3 M9,3 L9,15 M6,15 L12,15" /><TextBlock Text="Text" /></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.AddMarker" ToolTip="Add marker at playhead">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M5,2 L14,2 L14,10 L9.5,10 L6,14 L6,10 L5,10 Z" /><TextBlock Text="Marker" /></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.ExtractAudio" ToolTip="Extract audio from selected clip">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M3,7 L6,7 L10,3 L10,15 L6,11 L3,11 Z M13,6 C15,8 15,10 13,12" /><TextBlock Text="Audio" /></StackPanel>
                    </Button>
                    <Button Style="{StaticResource CommandButtonStyle}" Command="c:EditorCommands.GenerateMediaCache" ToolTip="Generate proxies, thumbnails, and waveforms">
                        <StackPanel Orientation="Horizontal"><Path Style="{StaticResource ToolbarIconStyle}" Data="M9,2 A7,7 0 1 0 16,9 M9,2 L12,2 M9,2 L9,5 M5,9 L8,12 L13,6" /><TextBlock Text="Cache" /></StackPanel>
                    </Button>
                    <Border Width="1" Height="24" Background="{StaticResource BorderBrush}" Margin="7,0" />
                    <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.Undo" ToolTip="Undo (Ctrl+Z)">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M7,5 L3,9 L7,13 M3,9 L11,9 C14,9 16,11 16,14" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" Command="c:EditorCommands.Redo" ToolTip="Redo (Ctrl+Y)">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M11,5 L15,9 L11,13 M15,9 L7,9 C4,9 2,11 2,14" />
                    </Button>
                </StackPanel>

                <TextBlock x:Name="ProjectNameText"
                           Grid.Column="1"
                           Text="Untitled Project"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="c:EditorCommands.Render"
                            MinWidth="92"
                            Margin="8,7,10,7"
                            ToolTip="Export project (Ctrl+R)">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource ToolbarIconStyle}" Stroke="White" Data="M3,12 L3,15 L15,15 L15,12 M9,2 L9,11 M5.5,7.5 L9,11 L12.5,7.5" />
                            <TextBlock Text="Export" Foreground="White" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MinimizeWindowButton"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Minimize">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,10 L14,10" />
                    </Button>
                    <Button x:Name="MaximizeWindowButton"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Maximize">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M4,4 L14,4 L14,14 L4,14 Z" />
                    </Button>
                    <Button x:Name="CloseWindowButton"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Close">
                        <Path Style="{StaticResource ToolbarIconStyle}" Margin="0" Data="M5,5 L13,13 M13,5 L5,13" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Editing workspace -->
        <Grid x:Name="MainGrid" Grid.Row="2" Background="{StaticResource WindowBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MediaColumn" Width="285" MinWidth="0" />
                <ColumnDefinition x:Name="MediaSplitterColumn" Width="5" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition x:Name="InspectorSplitterColumn" Width="5" />
                <ColumnDefinition x:Name="InspectorColumn" Width="330" MinWidth="0" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="260" />
                <RowDefinition Height="5" />
                <RowDefinition x:Name="TimelineRow" Height="335" MinHeight="180" />
            </Grid.RowDefinitions>

            <!-- Media browser -->
            <Border x:Name="MediaBorder"
                    Grid.Column="0"
                    Grid.Row="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="48" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelHeaderStyle}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Media" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock x:Name="MediaCountText" Text="0 items" Foreground="{StaticResource TextMutedBrush}" Margin="8,1,0,0" FontSize="11" />
                            </StackPanel>
                            <Button HorizontalAlignment="Right"
                                    Style="{StaticResource IconButtonStyle}"
                                    Content="＋"
                                    Command="c:EditorCommands.ImportMedia"
                                    ToolTip="Import media" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="10,10,10,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid>
                            <TextBox x:Name="MediaSearchBox" ToolTip="Filter media by file name" />
                            <TextBlock x:Name="MediaSearchHint"
                                       Text="Search media"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="9,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                        </Grid>
                        <Button x:Name="ClearMediaSearchButton"
                                Grid.Column="1"
                                Style="{StaticResource IconButtonStyle}"
                                Content="×"
                                Margin="5,0,0,0"
                                ToolTip="Clear search" />
                    </Grid>

                    <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="10,0,6,6">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="AllMediaFilterButton" Style="{StaticResource ChipButtonStyle}" Content="All" />
                            <Button x:Name="VideoFilterButton" Style="{StaticResource ChipButtonStyle}" Content="Video" />
                            <Button x:Name="ImageFilterButton" Style="{StaticResource ChipButtonStyle}" Content="Images" />
                            <Button x:Name="AudioFilterButton" Style="{StaticResource ChipButtonStyle}" Content="Audio" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="3">
                        <ListBox x:Name="MediaList" Margin="5,0,5,5" SelectionMode="Single">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="58">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="84" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="76"
                                                Height="48"
                                                CornerRadius="5"
                                                Background="#0B1015"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="{Binding FallbackGlyph}"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality" />
                                                <Border HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Background="#C012171D"
                                                        CornerRadius="0,0,4,0"
                                                        Padding="4,2">
                                                    <TextBlock Text="{Binding KindText}"
                                                               FontSize="8"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </Border>
                                                <Border HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Background="#D0000000"
                                                        CornerRadius="4,0,0,0"
                                                        Padding="4,2">
                                                    <TextBlock Text="{Binding DurationText}"
                                                               FontFamily="Consolas"
                                                               FontSize="9"
                                                               Foreground="White" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="9,1,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Asset.OriginalPath}" />
                                            <TextBlock Text="{Binding FolderPath}"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="9.5"
                                                       Margin="0,4,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Asset.OriginalPath}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <StackPanel x:Name="MediaEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                            <TextBlock Text="No media" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" />
                            <TextBlock Text="Import files or change the filter."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="4"
                            Background="{StaticResource ChromeBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PreviewSelectedMediaButton"
                                    Style="{StaticResource CommandButtonStyle}"
                                    Content="Preview"
                                    HorizontalAlignment="Left" />
                            <Button x:Name="AddToTimelineButton"
                                    Grid.Column="1"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Add to Timeline" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter x:Name="MediaSplitter"
                          Grid.Column="1"
                          Grid.Row="0"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Source preview -->
            <Border x:Name="PreviewBorder"
                    Grid.Column="2"
                    Grid.Row="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="32" />
                        <RowDefinition Height="46" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelHeaderStyle}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Source Preview" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="Selected media only"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="10"
                                           Margin="9,2,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="PreviewSourceNameText"
                                       Text="Nothing selected"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="260" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#030507"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Margin="12,10,12,6">
                        <Grid>
                            <Image x:Name="PreviewImage"
                                   Visibility="Collapsed"
                                   Stretch="Uniform" />
                            <MediaElement x:Name="PreviewPlayer"
                                          LoadedBehavior="Manual"
                                          UnloadedBehavior="Manual"
                                          Stretch="Uniform"
                                          ScrubbingEnabled="True"
                                          Volume="1" />
                            <Border HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#B00A0D12"
                                    CornerRadius="3"
                                    Padding="7,3"
                                    Margin="8">
                                <TextBlock Text="SOURCE" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="PreviewTimeText"
                                   Text="00:00"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="PreviewSeekSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="1"
                                Value="0"
                                Margin="8,0" />
                        <TextBlock x:Name="PreviewDurationText"
                                   Grid.Column="2"
                                   Text="00:00"
                                   FontFamily="Consolas"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <Grid Grid.Row="3" Background="{StaticResource ChromeBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="CPU-friendly source playback"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   Margin="12,0" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="PreviewStopButton" Style="{StaticResource TransportButtonStyle}" Content="■" ToolTip="Stop" />
                            <Button x:Name="PreviewPauseButton" Style="{StaticResource TransportButtonStyle}" Content="Ⅱ" ToolTip="Pause" />
                            <Button x:Name="PreviewPlayButton" Style="{StaticResource PrimaryButtonStyle}" Content="▶" MinWidth="46" Margin="4,0" ToolTip="Play" />
                        </StackPanel>
                        <TextBlock Grid.Column="2"
                                   Text="Timeline effects appear after export"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0" />
                    </Grid>
                </Grid>
            </Border>

            <GridSplitter x:Name="InspectorSplitter"
                          Grid.Column="3"
                          Grid.Row="0"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Inspector -->
            <Border x:Name="InspectorBorder"
                    Grid.Column="4"
                    Grid.Row="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelHeaderStyle}">
                        <Grid>
                            <TextBlock Text="Inspector" FontWeight="SemiBold" FontSize="13" />
                            <TextBlock x:Name="InspectorTitle"
                                       Text="No clip selected"
                                       HorizontalAlignment="Right"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="190" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid x:Name="InspectorPanel">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="52" />
                        </Grid.RowDefinitions>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="10">
                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Transform" Style="{StaticResource SectionTitleStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Position X" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="PositionXBox" Grid.Column="1" Margin="0,0,0,5" />
                                            <TextBlock Text="Position Y" Grid.Row="1" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="PositionYBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" />
                                            <TextBlock Text="Scale" Grid.Row="2" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="ScaleBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5" />
                                            <TextBlock Text="Rotation" Grid.Row="3" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="RotationBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,5" />
                                            <TextBlock Text="Opacity" Grid.Row="4" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="OpacityBox" Grid.Row="4" Grid.Column="1" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Timing" Style="{StaticResource SectionTitleStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Speed" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="SpeedBox" Grid.Column="1" />
                                        </Grid>
                                        <CheckBox x:Name="ReverseToggle" Content="Reverse playback" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Color" Style="{StaticResource SectionTitleStyle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="84" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Brightness" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="BrightnessBox" Grid.Column="1" Margin="0,0,0,5" />
                                            <TextBlock Text="Contrast" Grid.Row="1" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="ContrastBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5" />
                                            <TextBlock Text="Saturation" Grid.Row="2" Style="{StaticResource InspectorLabelStyle}" />
                                            <TextBox x:Name="SaturationBox" Grid.Row="2" Grid.Column="1" />
                                        </Grid>
                                        <CheckBox x:Name="BlackWhiteToggle" Content="Black and white" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Effects" Style="{StaticResource SectionTitleStyle}" />
                                        <ComboBox x:Name="EffectCombo" DisplayMemberPath="Name" />
                                        <Button x:Name="AddEffectButton" Content="Add Selected Effect" Margin="0,7,0,0" />
                                        <ListBox x:Name="EffectList" Height="82" Background="{StaticResource InputBrush}" Margin="0,7,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SectionCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Stabilization" Style="{StaticResource SectionTitleStyle}" />
                                        <CheckBox x:Name="StabilizeToggle" Content="Enable stabilization" />
                                        <Button x:Name="AnalyzeStabilizationButton" Content="Analyze Motion" Margin="0,7,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="1"
                                Background="{StaticResource ChromeBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="9">
                            <Button x:Name="ApplyInspectorButton"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="Apply Clip Settings"
                                    HorizontalAlignment="Stretch" />
                        </Border>
                        </Grid>

                        <StackPanel x:Name="InspectorEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="24"
                                    IsHitTestVisible="False">
                            <Border Width="44" Height="44" CornerRadius="12" Background="{StaticResource PanelRaisedBrush}" HorizontalAlignment="Center">
                                <TextBlock Text="◇" FontSize="22" Foreground="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="Select a timeline clip"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,12,0,0" />
                            <TextBlock Text="Its transform, timing, color and effects will appear here."
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       MaxWidth="230"
                                       Margin="0,5,0,0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- Timeline/work-area splitter -->
            <GridSplitter x:Name="PreviewTimelineSplitter"
                          Grid.Column="0"
                          Grid.ColumnSpan="5"
                          Grid.Row="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Timeline -->
            <Border x:Name="TimelineBorder"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="42" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource PanelHeaderStyle}">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Timeline" FontWeight="SemiBold" FontSize="13" Margin="0,0,14,0" VerticalAlignment="Center" />
                                <Button Style="{StaticResource CommandButtonStyle}" Content="Split" Command="c:EditorCommands.SplitClip" ToolTip="Split selected clip at playhead (Ctrl+B)" />
                                <Button Style="{StaticResource CommandButtonStyle}" Content="Duplicate" Command="c:EditorCommands.Duplicate" ToolTip="Duplicate selected clip (Ctrl+D)" />
                                <Button Style="{StaticResource CommandButtonStyle}" Content="Delete" Command="c:EditorCommands.DeleteClip" ToolTip="Delete selected clip" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <CheckBox x:Name="RippleToggle" Content="Ripple" IsChecked="False" ToolTip="Close gaps after supported edits" Margin="0,0,12,0" />
                                <CheckBox x:Name="SnapToggle" Content="Snap" IsChecked="True" ToolTip="Snap clips to nearby edges and markers" Margin="0,0,12,0" />
                                <TextBlock Text="Zoom" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,7,0" />
                                <Slider x:Name="ZoomSlider" Width="108" Minimum="0.1" Maximum="10" Value="1" TickFrequency="0.1" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ContentControl x:Name="TimelineHost" Grid.Row="1" />
                </Grid>
            </Border>

            <GridSplitter x:Name="TimelineTasksSplitter"
                          Grid.Column="3"
                          Grid.Row="2"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <!-- Tasks and render queue -->
            <Border x:Name="TasksBorder"
                    Grid.Column="4"
                    Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,1,0,0">
                <TabControl>
                    <TabItem x:Name="TasksTab" Header="Tasks">
                        <Grid>
                            <ListBox x:Name="TaskList" Margin="5" />
                            <TextBlock x:Name="TasksEmptyText"
                                       Text="No active tasks"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="RenderQueueTab" Header="Render Queue">
                        <Grid>
                            <ListBox x:Name="RenderQueueList" Margin="5" />
                            <TextBlock x:Name="RenderQueueEmptyText"
                                       Text="No render jobs"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False" />
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="MediaIntelligenceTab" Header="Media Intelligence">
                        <DockPanel Margin="5">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                <CheckBox x:Name="AnalyzeScenesToggle"
                                          Content="Scenes"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0" />
                                <CheckBox x:Name="AnalyzeTranscriptToggle"
                                          Content="Transcript"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0" />
                                <CheckBox x:Name="AnalyzeMusicToggle"
                                          Content="Music"
                                          IsChecked="True"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0" />
                                <CheckBox x:Name="AnalyzeGeminiToggle"
                                          Content="Gemini frames"
                                          VerticalAlignment="Center"
                                          Margin="0,0,12,0" />
                                <TextBlock Text="Whisper"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0" />
                                <ComboBox x:Name="WhisperModelCombo"
                                          Width="88"
                                          SelectedIndex="0"
                                          Margin="0,0,8,0">
                                    <ComboBoxItem Content="base" />
                                    <ComboBoxItem Content="small" />
                                    <ComboBoxItem Content="medium" />
                                </ComboBox>
                                <Button x:Name="RunMediaIntelligenceButton"
                                        Content="Run"
                                        MinWidth="58"
                                        Margin="0,0,6,0" />
                                <Button x:Name="ApplyMediaIntelligenceButton"
                                        Content="Add to Timeline"
                                        MinWidth="112"
                                        Margin="0,0,6,0"
                                        ToolTip="Create scene markers and caption clips for the selected timeline clip" />
                                <Button x:Name="OpenMediaAnalysisButton"
                                        Content="Open Output"
                                        MinWidth="96" />
                            </StackPanel>
                            <Grid>
                                <ListBox x:Name="MediaIntelligenceList" />
                                <TextBlock x:Name="MediaIntelligenceEmptyText"
                                           Text="Select media, then run scene/transcript/music analysis"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False" />
                            </Grid>
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="10" />
                <TextBlock Grid.Column="1" Text="Rushframe · CPU editing mode" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="10" />
                <TextBlock Grid.Column="2" Text="Autosave: 30 seconds" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10" />
            </Grid>
        </Border>
    </Grid>
</Window>
