<Window x:Class="CreatorCut.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:CreatorCut.Desktop.Commands"
        Title="CreatorCut" Height="720" Width="1280"
        WindowStartupLocation="CenterScreen">

    <Window.CommandBindings>
        <CommandBinding Command="c:EditorCommands.TogglePanel" Executed="TogglePanel_Executed" />
    </Window.CommandBindings>

    <Window.Resources>
        <ContextMenu x:Key="TimelineClipContextMenu">
            <MenuItem Header="_Split Clip" Command="c:EditorCommands.SplitClip" />
            <MenuItem Header="Cu_t" Command="c:EditorCommands.Cut" />
            <MenuItem Header="_Copy" Command="c:EditorCommands.Copy" />
            <MenuItem Header="_Paste" Command="c:EditorCommands.Paste" />
            <MenuItem Header="_Duplicate" Command="c:EditorCommands.Duplicate" />
            <Separator />
            <MenuItem Header="Ripple _Delete" Command="c:EditorCommands.RippleDelete" />
            <MenuItem Header="_Delete" Command="c:EditorCommands.DeleteClip" />
        </ContextMenu>

        <ContextMenu x:Key="TrackHeaderContextMenu">
            <MenuItem Header="_Rename Track" x:Name="RenameTrackMenuItem" />
            <MenuItem Header="_Duplicate Track" x:Name="DuplicateTrackMenuItem" />
            <Separator />
            <MenuItem Header="_Mute Track" x:Name="MuteTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="_Solo Track" x:Name="SoloTrackMenuItem" IsCheckable="True" />
            <MenuItem Header="Loc_k Track" x:Name="LockTrackMenuItem" IsCheckable="True" />
            <Separator />
            <MenuItem Header="_Delete Track" x:Name="DeleteTrackMenuItem" />
        </ContextMenu>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Project" Command="c:EditorCommands.OpenProject" />
                <MenuItem Header="_Save Project" Command="c:EditorCommands.SaveProject" />
                <Separator />
                <MenuItem Header="_Import Media..." Command="c:EditorCommands.ImportMedia" />
                <Separator />
                <MenuItem Header="_Render..." Command="c:EditorCommands.Render" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="c:EditorCommands.Undo" />
                <MenuItem Header="_Redo" Command="c:EditorCommands.Redo" />
                <Separator />
                <MenuItem Header="Cu_t" Command="c:EditorCommands.Cut" />
                <MenuItem Header="_Copy" Command="c:EditorCommands.Copy" />
                <MenuItem Header="_Paste" Command="c:EditorCommands.Paste" />
                <Separator />
                <MenuItem Header="_Split Clip" Command="c:EditorCommands.SplitClip" />
                <MenuItem Header="_Delete" Command="c:EditorCommands.DeleteClip" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Panels" x:Name="PanelsMenu" />
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <CheckBox x:Name="RippleToggle" Content="Ripple" IsChecked="False"
                      ToolTip="Ripple mode: close gaps automatically" />
            <CheckBox x:Name="SnapToggle" Content="Snap" IsChecked="True"
                      ToolTip="Snap to item edges and markers" />
            <Separator />
            <Label Content="Zoom:" />
            <Slider x:Name="ZoomSlider" Width="120" Minimum="0.1" Maximum="10" Value="1"
                    TickFrequency="0.1" IsSnapToTickEnabled="True" />
        </ToolBar>

        <Grid x:Name="MainGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" x:Name="MediaColumn" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="280" x:Name="InspectorColumn" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="220" x:Name="TimelineRow" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="180" x:Name="TasksRow" />
            </Grid.RowDefinitions>

            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="5"
                    BorderBrush="#ccc" BorderThickness="0,0,1,0"
                    x:Name="MediaBorder">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Padding="8,4" FontWeight="SemiBold"
                               Background="#eee">Media</TextBlock>
                    <ListBox x:Name="MediaList" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="5"
                          Width="4" HorizontalAlignment="Center"
                          ResizeBehavior="PreviousAndNext"
                          x:Name="MediaSplitter" />

            <Border Grid.Column="2" Grid.Row="0"
                    BorderBrush="#ccc" BorderThickness="0,0,0,1"
                    x:Name="PreviewBorder">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Padding="8,4" FontWeight="SemiBold"
                               Background="#eee">Preview</TextBlock>
                    <Border Background="Black" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="2" Grid.Row="1"
                          Height="4" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          x:Name="PreviewTimelineSplitter" />

            <Border Grid.Column="2" Grid.Row="2"
                    BorderBrush="#ccc" BorderThickness="0,0,0,1"
                    x:Name="TimelineBorder">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Padding="8,4" FontWeight="SemiBold"
                               Background="#eee">Timeline</TextBlock>
                    <ContentControl x:Name="TimelineHost" Margin="0,0,0,0" />
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="2" Grid.Row="3"
                          Height="4" HorizontalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          x:Name="TimelineTasksSplitter" />

            <Border Grid.Column="2" Grid.Row="4" Grid.ColumnSpan="3"
                    BorderBrush="#ccc" BorderThickness="0,0,0,0"
                    x:Name="TasksBorder">
                <TabControl>
                    <TabItem Header="Tasks / Campaign">
                        <ListBox x:Name="TaskList" />
                    </TabItem>
                    <TabItem Header="Render Queue">
                        <ListBox x:Name="RenderQueueList" />
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="4" Grid.Row="0" Grid.RowSpan="4"
                    BorderBrush="#ccc" BorderThickness="1,0,0,0"
                    x:Name="InspectorBorder">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Padding="8,4" FontWeight="SemiBold"
                               Background="#eee">Inspector</TextBlock>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Grid.Row="0" Grid.RowSpan="4"
                          Width="4" HorizontalAlignment="Center"
                          ResizeBehavior="PreviousAndNext"
                          x:Name="InspectorSplitter" />
        </Grid>
    </DockPanel>
</Window>
